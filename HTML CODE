<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Disaster Safety Hub | Emergency Response</title>
    <meta name="description" content="Get immediate safety precautions for natural disasters and quick access to emergency SOS numbers.">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #2563eb;
            --secondary: #dc2626;
            --bg-gradient: linear-gradient(135deg, #1e3a8a 0%, #9333ea 100%);
            --card-bg: rgba(255, 255, 255, 0.95);
        }

        body, html {
            margin: 0;
            padding: 0;
            font-family: 'Inter', sans-serif;
            background: var(--bg-gradient);
            background-attachment: fixed;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .container {
            width: 90%;
            max-width: 500px;
            background: var(--card-bg);
            padding: 30px;
            border-radius: 24px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.3);
            text-align: center;
            transition: all 0.3s ease;
        }

        /* Login Section */
        #login-screen { display: block; }
        #app-screen { display: none; }

        h1 { color: #1e293b; margin-bottom: 10px; font-weight: 800; }
        p { color: #64748b; margin-bottom: 30px; }

        .google-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            background: white;
            border: 1px solid #ddd;
            padding: 12px;
            border-radius: 12px;
            cursor: pointer;
            font-weight: 600;
            width: 100%;
            transition: 0.2s;
        }
        .google-btn:hover { background: #f8fafc; transform: translateY(-2px); }
        .google-btn img { width: 20px; margin-right: 10px; }

        /* App Section */
        .welcome-header {
            text-align: left;
            border-bottom: 2px solid #f1f5f9;
            padding-bottom: 15px;
            margin-bottom: 20px;
        }
        .user-badge {
            background: #dbeafe;
            color: var(--primary);
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.9rem;
        }

        .location-tag {
            font-size: 0.8rem;
            color: #ef4444;
            font-weight: 600;
            margin-top: 5px;
        }

        .disaster-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
            margin-bottom: 25px;
        }

        .disaster-card {
            background: #f8fafc;
            padding: 20px;
            border-radius: 15px;
            cursor: pointer;
            border: 2px solid transparent;
            transition: 0.2s;
            font-weight: 600;
        }
        .disaster-card:hover {
            border-color: var(--primary);
            background: #eff6ff;
        }

        /* SOS Button */
        .sos-btn {
            background: var(--secondary);
            color: white;
            padding: 18px;
            border-radius: 15px;
            text-decoration: none;
            display: block;
            font-weight: 800;
            font-size: 1.2rem;
            margin-top: 20px;
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0% { transform: scale(1); }
            50% { transform: scale(1.03); }
            100% { transform: scale(1); }
        }

        /* Modal / Precautions */
        #precaution-box {
            display: none;
            background: #fff4f4;
            border-left: 5px solid #ef4444;
            padding: 15px;
            margin-top: 20px;
            text-align: left;
            border-radius: 8px;
        }
    </style>
</head>
<body>

    <div class="container">
        <div id="login-screen">
            <h1>Disaster Safety Hub</h1>
            <p>Stay informed, stay safe. Please sign in to access local emergency data.</p>
            <button class="google-btn" onclick="login()">
                <img src="https://upload.wikimedia.org/wikipedia/commons/5/53/Google_%22G%22_Logo.svg" alt="Google">
                Sign up with Google
            </button>
        </div>

        <div id="app-screen">
            <div class="welcome-header">
                <h2>Hello, Welcome <span id="username" class="user-badge">User</span></h2>
                <div class="location-tag" id="location-text">📍 Locating your area...</div>
            </div>

            <p style="text-align: left; margin-bottom: 10px;"><strong>Select a disaster for immediate steps:</strong></p>
            <div class="disaster-grid">
                <div class="disaster-card" onclick="showSafety('Earthquake')">🌋 Earthquake</div>
                <div class="disaster-card" onclick="showSafety('Flood')">🌊 Flood</div>
                <div class="disaster-card" onclick="showSafety('Cyclone')">🌀 Cyclone</div>
                <div class="disaster-card" onclick="showSafety('Tsunami')">🌊 Tsunami</div>
            </div>

            <div id="precaution-box">
                <strong id="disaster-title">Precautions</strong>
                <ul id="precaution-list" style="padding-left: 20px; font-size: 0.9rem; margin-top: 10px;"></ul>
            </div>

            <a href="tel:100" class="sos-btn">🚨 CALL EMERGENCY POLICE</a>
        </div>
    </div>

    <script>
        // Mock Login Function
        function login() {
            document.getElementById('login-screen').style.display = 'none';
            document.getElementById('app-screen').style.display = 'block';
            document.getElementById('username').innerText = "Friend"; // In a real app, this comes from Google API
            getLocation();
        }

        // Get Location
        function getLocation() {
            if (navigator.geolocation) {
                navigator.geolocation.getCurrentPosition((position) => {
                    document.getElementById('location-text').innerText = "📍 Region Secured: Active Monitoring";
                }, () => {
                    document.getElementById('location-text').innerText = "📍 Location access denied";
                });
            }
        }

        // Safety Data
        const safetyTips = {
            'Earthquake': ["Drop to the ground", "Cover your head and neck", "Hold on until shaking stops", "Stay away from glass and outer walls"],
            'Flood': ["Move to higher ground immediately", "Do not walk or drive through water", "Turn off electricity at the main switch", "Boil water before drinking"],
            'Cyclone': ["Stay indoors in a strong building", "Keep away from windows", "Unplug all electrical appliances", "Stay tuned to local radio for updates"],
            'Tsunami': ["Move inland to high ground immediately", "If you see the ocean recede, run away from the shore", "Wait for official 'All Clear' before returning"]
        };

        function showSafety(type) {
            const box = document.getElementById('precaution-box');
            const list = document.getElementById('precaution-list');
            const title = document.getElementById('disaster-title');
            
            box.style.display = 'block';
            title.innerText = "Immediate " + type + " Precautions:";
            list.innerHTML = "";
            
            safetyTips[type].forEach(tip => {
                let li = document.createElement('li');
                li.innerText = tip;
                list.appendChild(li);
            });
        }
    </script>
</body>
</html>
